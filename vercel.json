{
  "git": {
    "deploymentEnabled": {
      "claude/agent-audit-gold-trading-gum3j3": false
    }
  },
  "crons": [
    {
      "path": "/api/market/trump/cnn-sync",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/telegram-screener",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
