<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:paddingLeft="14dp"
    android:paddingRight="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ TradeX"
            android:textColor="#5fc77a"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textColor="#555555"
            android:textSize="9sp" />

        <!-- Invisible tap target for manual refresh -->
        <TextView
            android:id="@+id/widget_refresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="↻"
            android:textColor="#5fc77a"
            android:textSize="14sp"
            android:layout_marginLeft="6dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginBottom="8dp" />

    <!-- Row: GOLD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="GOLD"
            android:textColor="#888888"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/xau_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="-----.--"
            android:textColor="#EEEEEE"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/xau_change"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="+0.00%"
            android:textColor="#5fc77a"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Row: DXY -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="DXY"
            android:textColor="#888888"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dxy_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="---.--"
            android:textColor="#EEEEEE"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/dxy_change"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="+0.00%"
            android:textColor="#5fc77a"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Row: BTC -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="BTC"
            android:textColor="#888888"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btc_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="------.--"
            android:textColor="#EEEEEE"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/btc_change"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="+0.00%"
            android:textColor="#5fc77a"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Row: EUR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="EUR"
            android:textColor="#888888"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/eur_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="-.-----"
            android:textColor="#EEEEEE"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/eur_change"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="+0.00%"
            android:textColor="#5fc77a"
            android:textSize="10sp"
            android:fontFamily="monospace" />
    </LinearLayout>

</LinearLayout>
